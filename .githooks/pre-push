#!/usr/bin/env bash
# Pre-push: block pushes that fail `npm run build`. Skip when only
# public/data/* changed (Mac mini's recurring price refresh).
#
# Install (once per clone):  git config core.hooksPath .githooks

set -euo pipefail

zero="0000000000000000000000000000000000000000"
need_build=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue   # branch deletion — nothing to build

  if [ "$remote_sha" = "$zero" ]; then
    # New branch — diff against origin/main as a sane baseline. If that fails
    # (no main locally), just build to be safe.
    if base=$(git merge-base "$local_sha" origin/main 2>/dev/null); then
      range="$base..$local_sha"
    else
      need_build=1
      break
    fi
  else
    range="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$range" | grep -qv '^public/data/'; then
    need_build=1
    break
  fi
done

if [ "$need_build" -eq 1 ]; then
  echo "pre-push: code changes detected — running npm run build"
  cd "$(git rev-parse --show-toplevel)"
  npm run build
else
  echo "pre-push: data-only push — skipping build"
fi
